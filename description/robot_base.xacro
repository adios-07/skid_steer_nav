<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <xacro:include filename="inertial_macros.xacro"/>
     <xacro:arg name="namespace" default="" />

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>


    <!-- BASE FOOTPRINT LINK -->

    <link name="base_footprint">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </link>


    <!-- BASE LINK -->

    <joint name="base_joint" type="fixed">
        <origin xyz="0.0 0.0 0.03" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.02"/>
            <geometry>
                <box size="0.3 0.2 0.04"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.02"/>
            <geometry>
                <box size="0.3 0.2 0.04"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="5" x="0.3" y="0.2" z="0.04">
            <origin xyz="0 0 0.02" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_box>       
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/Orange</material>
    </gazebo>

    <!-- LEFT WHEEL LINK-->

    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.12 0.115 0.0" rpy="-${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 1.0"/>
        <!-- <limit effort="1000" velocity="100"/> -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="front_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.6" length="0.03" radius="0.03">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>0.7</mu2>
        <kp>200000.0</kp>
        <kd>5000.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>10</maxVel>
        <fdir1>0 1 0</fdir1>
    </gazebo>

    <joint name="back_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="back_left_wheel"/>
        <origin xyz="-0.12 0.115 0.0" rpy="-${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 1.0"/>
        <!-- <limit effort="1000" velocity="100"/> -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="back_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>

        </collision>

        <xacro:inertial_cylinder mass="0.6" length="0.03" radius="0.03">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="back_left_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>0.7</mu2>
        <kp>200000.0</kp>
        <kd>5000.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>10</maxVel>
        <fdir1>0 1 0</fdir1>
    </gazebo>





    <!-- RIGHT WHEEL LINK-->

    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.12 -0.115 0.0" rpy="${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 -1.0"/>
        <!-- <limit effort="1000" velocity="100"/> -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="front_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>

        </collision>
        <xacro:inertial_cylinder mass="0.6" length="0.03" radius="0.03">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="front_right_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>0.7</mu2>
        <kp>200000.0</kp>
        <kd>5000.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>10</maxVel>
        <fdir1>0 1 0</fdir1>
    </gazebo>



    <joint name="back_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="back_right_wheel"/>
        <origin xyz="-0.12 -0.115 0.0" rpy="${pi/2} 0.0 0.0"/>
        <axis xyz="0.0 0.0 -1.0"/>
        <!-- <limit effort="100" velocity="100"/> -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="back_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.03" length="0.03"/>
            </geometry>

        </collision>
        <xacro:inertial_cylinder mass="0.6" length="0.03" radius="0.03">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="back_right_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>0.7</mu2>
        <kp>200000.0</kp>
        <kd>5000.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>10</maxVel>
        <fdir1>0 1 0</fdir1>
    </gazebo>
</robot>
